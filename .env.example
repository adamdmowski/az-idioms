# Supabase project credentials for the shared Wall of Fame (Phase 7).
# Copy this file to `.env.local` and fill in real values from your Supabase
# project dashboard → Settings → API. Restart `npm run dev` after editing.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Cloud Text-to-Speech API key — Phase 8.
# Only used by the `npm run generate-audio` script. Never read at runtime.
GOOGLE_TTS_API_KEY=your-google-tts-api-key
